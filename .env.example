# AlphaLoop v3 — Environment Variables
# Copy this file to .env and fill in your values.
# .env is loaded at startup for initial bootstrap only.
# All runtime config is managed via the WebUI Settings tab (stored in DB).

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, dev):
DATABASE_URL=sqlite+aiosqlite:///alphaloop.db
# PostgreSQL (prod):
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost/alphaloop

# ── MetaTrader 5 ──────────────────────────────────────────────────────────────
MT5_LOGIN=12345678
MT5_PASSWORD=your_password
MT5_SERVER=YourBroker-MT5Live
MT5_SYMBOL=XAUUSDm

# ── AI APIs ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
GEMINI_API_KEY=AIzaSy...
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# XAI_API_KEY=
# QWEN_API_KEY=

# ── News / Economic Calendar (Finnhub) ───────────────────────────────────────
# Get free key at: https://finnhub.io/ (free tier: 60 req/min, includes calendar)
# Without this key, news_filter blocks ALL trades as a safety precaution.
# NEWS_API_KEY=your_finnhub_key_here

# ── Telegram (optional) ──────────────────────────────────────────────────────
# TELEGRAM_TOKEN=
# TELEGRAM_CHAT_ID=

# ── Trading ───────────────────────────────────────────────────────────────────
DRY_RUN=true
RISK_PCT=1.0
LOG_LEVEL=INFO
ENVIRONMENT=dev

# ── WebUI Auth ───────────────────────────────────────────────────────────────
# Required for sensitive endpoints (agent deploy, settings, strategies).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AUTH_TOKEN=
